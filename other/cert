#!/bin/bash

# Set error handling
set -euo pipefail

# Log file untuk proses debug
LOG_FILE="/var/log/renew_cert.log"
exec > >(tee -a "$LOG_FILE") 2>&1

echo "==== Memulai proses pembaruan sertifikat ===="

# Menghapus folder .acme.sh jika ada
if [ -d ~/.acme.sh ]; then
  echo "Menghapus direktori .acme.sh..."
  rm -rf ~/.acme.sh
fi

# Mematikan layanan Docker Marzban
echo "Menghentikan layanan Docker Marzban..."
cd /opt/marzban && docker compose down

# Kembali ke home directory
cd || exit

# Konfigurasi domain dan email
DOMAIN1=$(cat /etc/data/domain1)
DOMAIN2=$(cat /etc/data/domain2)
EMAIL=$(cat /etc/data/email)

# Validasi konfigurasi
if [[ -z "$DOMAIN1" || -z "$DOMAIN2" || -z "$EMAIL" ]]; then
  echo "Error: DOMAIN1, DOMAIN2, atau EMAIL tidak diatur dengan benar."
  exit 1
fi

# Menginstal acme.sh
echo "Mengunduh dan menginstal acme.sh..."
curl https://get.acme.sh | sh -s email="$EMAIL"

# Atur Let's Encrypt sebagai server CA default
echo "Mengatur Let's Encrypt sebagai CA default..."
~/.acme.sh/acme.sh --set-default-ca --server letsencrypt

# Mendaftarkan akun dan menerbitkan sertifikat untuk domain pertama
echo "Mendaftarkan akun dan menerbitkan sertifikat untuk $DOMAIN1..."
~/.acme.sh/acme.sh --register-account -m "$EMAIL"
~/.acme.sh/acme.sh --issue -d "$DOMAIN1" --standalone -k ec-256

# Memasang sertifikat untuk domain pertama
echo "Memasang sertifikat untuk $DOMAIN1..."
~/.acme.sh/acme.sh --installcert -d "$DOMAIN1" \
  --fullchainpath /var/lib/marzban/certs/domain1/xray.crt \
  --keypath /var/lib/marzban/certs/domain1/xray.key --ecc

# Mendaftarkan akun dan menerbitkan sertifikat untuk domain kedua
echo "Mendaftarkan akun dan menerbitkan sertifikat untuk $DOMAIN2..."
~/.acme.sh/acme.sh --issue -d "$DOMAIN2" --standalone -k ec-256

# Memasang sertifikat untuk domain kedua
echo "Memasang sertifikat untuk $DOMAIN2..."
~/.acme.sh/acme.sh --installcert -d "$DOMAIN2" \
  --fullchainpath /var/lib/marzban/certs/domain2/xray.crt \
  --keypath /var/lib/marzban/certs/domain2/xray.key --ecc

# Menghidupkan kembali layanan Docker Marzban
echo "Menghidupkan kembali layanan Docker Marzban..."
cd /opt/marzban && docker compose up -d

# Kembali ke home directory
cd || exit

echo "==== Proses pembaruan sertifikat selesai ===="
